    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        Toolbar toolbar = (Toolbar) findViewById(R.id.toolbar);
        setSupportActionBar(toolbar);

        outputDir = new File(Environment.getExternalStorageDirectory(), OUTPUT_DIR_NAME);
        if (!outputDir.exists()) {
            outputDir.mkdirs();
        }

        if (ContextCompat.checkSelfPermission(this, Manifest.permission.WRITE_EXTERNAL_STORAGE)
                != PackageManager.PERMISSION_GRANTED) {
            ActivityCompat.requestPermissions(this,
                    new String[]{
                            Manifest.permission.WRITE_EXTERNAL_STORAGE,
                            Manifest.permission.READ_EXTERNAL_STORAGE
                    }, PERMISSION_REQUEST_CODE);
        }

        initRecyclerView();
    }

    @Override
    public void onRequestPermissionsResult(int requestCode, @NonNull String[] permissions,
                                           @NonNull int[] grantResults) {
        super.onRequestPermissionsResult(requestCode, permissions, grantResults);
        if (requestCode == PERMISSION_REQUEST_CODE) {
            if (grantResults.length > 0 && grantResults[0] != PackageManager.PERMISSION_GRANTED) {
                Toast.makeText(this, "需要存储权限才能输出模块文件", Toast.LENGTH_LONG).show();
            }
        }
    }

    private void initRecyclerView() {
        recyclerView = findViewById(R.id.recyclerView);
        recyclerView.setLayoutManager(new LinearLayoutManager(this));

        List<FunctionAdapter.FunctionItem> items = new ArrayList<>();
        items.add(new FunctionAdapter.FunctionItem(1, "普通应用转系统应用", "将第三方应用固化为系统应用，支持APK和lib提取"));
        items.add(new FunctionAdapter.FunctionItem(2, "修改/system分区文件", "替换/system目录中的文件，需提供目标路径和替换文件"));
        items.add(new FunctionAdapter.FunctionItem(3, "修改/vendor分区文件", "替换/vendor目录中的文件，适用于vendor自定义"));
        items.add(new FunctionAdapter.FunctionItem(4, "修改系统属性", "批量修改系统属性（system.prop），如调试/性能调整"));
        items.add(new FunctionAdapter.FunctionItem(5, "开机动画模块", "替换开机动画，支持bootanimation.zip或帧目录构建"));
        items.add(new FunctionAdapter.FunctionItem(6, "修改机型信息", "修改设备型号/品牌/制造商等属性"));
        items.add(new FunctionAdapter.FunctionItem(7, "自定义Hosts模块", "替换系统hosts文件，用于广告屏蔽或自定义DNS"));
        items.add(new FunctionAdapter.FunctionItem(8, "开机自启脚本模块", "创建开机启动脚本（service.sh 或 post-fs-data.sh）"));
        items.add(new FunctionAdapter.FunctionItem(10, "字体替换模块", "替换系统字体，支持1-9字重（Thin到Black）"));

        adapter = new FunctionAdapter(items, new FunctionAdapter.OnItemClickListener() {
            @Override
            public void onItemClick(int position, FunctionAdapter.FunctionItem item) {
                switch (item.id) {
                    case 1: showAppToSystemDialog(); break;
                    case 2: showFileReplaceDialog("system"); break;
                    case 3: showFileReplaceDialog("vendor"); break;
                    case 4: showSystemPropDialog(); break;
                    case 5: showBootAnimationDialog(); break;
                    case 6: showDeviceModelDialog(); break;
                    case 7: showHostsDialog(); break;
                    case 8: showStartupScriptDialog(); break;
                    case 10: showFontModuleDialog(); break;
                }
            }
        });
        recyclerView.setAdapter(adapter);
    }

    // ==================== 1: 应用转系统应用 ====================
    private void showAppToSystemDialog() {
        final List<AppToSystemFactory.AppInfo> appList = AppToSystemFactory.getInstalledApps(this);
        if (appList.isEmpty()) {
            Toast.makeText(this, "没有找到第三方应用", Toast.LENGTH_SHORT).show();
            return;
        }

        final String[] appNames = new String[appList.size()];
        for (int i = 0; i < appList.size(); i++) {
            appNames[i] = appList.get(i).toString();
        }

        new AlertDialog.Builder(this)
                .setTitle("选择应用转系统应用")
                .setItems(appNames, new DialogInterface.OnClickListener() {
                    @Override
                    public void onClick(DialogInterface dialog, int which) {
                        final AppToSystemFactory.AppInfo selected = appList.get(which);
                        new AlertDialog.Builder(MainActivity.this)
                                .setTitle("确认操作")
                                .setMessage("将 " + selected.packageName + " 转化为系统应用？\n\n此操作不会修改当前系统分区，生成的Magisk模块可自行刷入。")
                                .setPositiveButton("生成模块", new DialogInterface.OnClickListener() {
                                    @Override
                                    public void onClick(DialogInterface d, int w) {
                                        executeAsync("正在生成应用转系统模块...", new Runnable() {
                                            @Override
                                            public void run() {
                                                try {
                                                    File zip = AppToSystemFactory.createModule(MainActivity.this, selected, outputDir);
                                                    showResult(zip, "应用转系统模块");
                                                } catch (Exception e) {
                                                    showError(e);
                                                }
                                            }
                                        });
                                    }
                                })
                                .setNegativeButton("取消", null)
                                .show();
                    }
                })
                .setNegativeButton("取消", null)
                .show();
    }

    // ==================== 2/3: 文件替换 ====================
    private void showFileReplaceDialog(final String partition) { // final already
        LinearLayout layout = new LinearLayout(this);
        layout.setOrientation(LinearLayout.VERTICAL);
        layout.setPadding(32, 16, 32, 0);

        final EditText etTargetPath = new EditText(this);
        etTargetPath.setHint("目标文件路径（如 /" + partition + "/build.prop）");
        layout.addView(etTargetPath);

        final EditText etSourcePath = new EditText(this);
        etSourcePath.setHint("替换源文件完整路径");
        etSourcePath.setPadding(0, 16, 0, 0);
        layout.addView(etSourcePath);

        new AlertDialog.Builder(this)
                .setTitle("修改/" + partition + " 分区文件")
                .setView(layout)
                .setPositiveButton("生成模块", new DialogInterface.OnClickListener() {
                    @Override
                    public void onClick(DialogInterface d, int w) {
                        final String target = etTargetPath.getText().toString().trim();
                        final String source = etSourcePath.getText().toString().trim();
                        if (TextUtils.isEmpty(target) || TextUtils.isEmpty(source)) {
                            Toast.makeText(MainActivity.this, "请填写完整信息", Toast.LENGTH_SHORT).show();
                            return;
                        }
                        final File sourceFile = new File(source);
                        if (!sourceFile.exists()) {
                            Toast.makeText(MainActivity.this, "源文件不存在", Toast.LENGTH_SHORT).show();
                            return;
                        }
                        executeAsync("正在生成" + partition + "文件替换模块...", new Runnable() {
                            @Override
                            public void run() {
                                try {
                                    File zip = FileReplaceFactory.createModule(
                                            MainActivity.this, partition, target, sourceFile, outputDir);
                                    showResult(zip, partition + "文件替换模块");
                                } catch (Exception e) {
                                    showError(e);
                                }
                            }
                        });
                    }
                })
                .setNegativeButton("取消", null)
                .show();
    }

