    // ==================== 10: 字体替换 ====================
    private void showFontModuleDialog() {
        final String[] weightNames = {
                "1 - Thin（最细）", "2 - ExtraLight", "3 - Light",
                "4 - Regular（常规）", "5 - Medium", "6 - SemiBold",
                "7 - Bold（粗体）", "8 - ExtraBold", "9 - Black（最粗）"
        };

        LinearLayout layout = new LinearLayout(this);
        layout.setOrientation(LinearLayout.VERTICAL);
        layout.setPadding(32, 16, 32, 0);

        TextView tvHint = new TextView(this);
        tvHint.setText("请为每个需要的字重指定字体文件路径，不需要的字重留空即可：");
        tvHint.setTextSize(13);
        layout.addView(tvHint);

        final EditText[] etWeights = new EditText[9];
        for (int i = 0; i < 9; i++) {
            EditText et = new EditText(this);
            et.setHint(weightNames[i]);
            et.setPadding(0, 8, 0, 0);
            layout.addView(et);
            etWeights[i] = et;
        }

        new AlertDialog.Builder(this)
                .setTitle("字体替换模块")
                .setView(layout)
                .setPositiveButton("生成模块", new DialogInterface.OnClickListener() {
                    @Override
                    public void onClick(DialogInterface d, int w) {
                        final Map<Integer, File> fontMap = new HashMap<Integer, File>();
                        for (int i = 0; i < 9; i++) {
                            String path = etWeights[i].getText().toString().trim();
                            if (!TextUtils.isEmpty(path)) {
                                File fontFile = new File(path);
                                if (fontFile.exists()) {
                                    fontMap.put(i + 1, fontFile);
                                }
                            }
                        }
                        if (fontMap.isEmpty()) {
                            Toast.makeText(MainActivity.this, "请至少指定一个字体文件", Toast.LENGTH_SHORT).show();
                            return;
                        }
                        executeAsync("正在生成字体替换模块...", new Runnable() {
                            @Override
                            public void run() {
                                try {
                                    File zip = FontModuleFactory.createModule(MainActivity.this, fontMap, outputDir);
                                    showResult(zip, "字体替换模块");
                                } catch (Exception e) {
                                    showError(e);
                                }
                            }
                        });
                    }
                })
                .setNegativeButton("取消", null)
                .show();
    }

    // ==================== 通用工具方法 ====================

    private void executeAsync(String progressMessage, final Runnable task) {
        final ProgressDialog pd = ProgressDialog.show(this, "请稍候", progressMessage, true, false);
        executor.execute(new Runnable() {
            @Override
            public void run() {
                try {
                    task.run();
                } finally {
                    mainHandler.post(new Runnable() {
                        @Override
                        public void run() {
                            try { pd.dismiss(); } catch (Exception ignored) {}
                        }
                    });
                }
            }
        });
    }

    private void showResult(final File zip, final String moduleName) { // params already final
        mainHandler.post(new Runnable() {
            @Override
            public void run() {
                if (zip != null && zip.exists()) {
                    new AlertDialog.Builder(MainActivity.this)
                            .setTitle("模块生成成功")
                            .setMessage("模块名称：" + zip.getName()
                                    + "\n位置：" + zip.getAbsolutePath()
                                    + "\n大小：" + formatFileSize(zip.length())
                                    + "\n\n是否需要安装此模块？")
                            .setPositiveButton("立即安装", new DialogInterface.OnClickListener() {
                                @Override
                                public void onClick(DialogInterface d, int w) {
                                    installModule(zip);
                                }
                            })
                            .setNegativeButton("暂不安装", null)
                            .show();
                } else {
                    Toast.makeText(MainActivity.this, "模块生成失败", Toast.LENGTH_SHORT).show();
                }
            }
        });
    }

    private void installModule(final File moduleZip) { // param already final
        if (!ModuleInstaller.hasRootAccess()) {
            Toast.makeText(this, "未检测到root权限，无法安装", Toast.LENGTH_LONG).show();
            return;
        }
        new AlertDialog.Builder(this)
                .setTitle("确认安装")
                .setMessage("即将安装：\n" + moduleZip.getName()
                        + "\n\n请确保已安装Magisk/KernelSU/APatch")
                .setPositiveButton("安装", new DialogInterface.OnClickListener() {
                    @Override
                    public void onClick(DialogInterface d, int w) {
                        executeAsync("正在安装模块...", new Runnable() {
                            @Override
                            public void run() {
                                final boolean ok = ModuleInstaller.installModule(moduleZip);
                                mainHandler.post(new Runnable() {
                                    @Override
                                    public void run() {
                                        if (ok) {
                                            new AlertDialog.Builder(MainActivity.this)
                                                    .setTitle("安装完成")
                                                    .setMessage("模块已安装，请重启设备使其生效。")
                                                    .setPositiveButton("确定", null)
                                                    .show();
                                        } else {
                                            Toast.makeText(MainActivity.this, "安装失败，请检查root权限和Magisk状态", Toast.LENGTH_LONG).show();
                                        }
                                    }
                                });
                            }
                        });
                    }
                })
                .setNegativeButton("取消", null)
                .show();
    }

    private void showError(final Exception e) { // param already final
        mainHandler.post(new Runnable() {
            @Override
            public void run() {
                String msg = e.getMessage() != null ? e.getMessage() : e.getClass().getSimpleName();
                new AlertDialog.Builder(MainActivity.this)
                        .setTitle("生成失败")
                        .setMessage("错误信息：\n" + msg)
                        .setPositiveButton("确定", null)
                        .show();
            }
        });
    }

    private String formatFileSize(long size) {
        if (size < 1024) return size + " B";
        if (size < 1024 * 1024) return String.format("%.1f KB", size / 1024.0);
        return String.format("%.2f MB", size / (1024.0 * 1024.0));
    }

    @Override
    protected void onDestroy() {
        super.onDestroy();
        executor.shutdown();
    }
}