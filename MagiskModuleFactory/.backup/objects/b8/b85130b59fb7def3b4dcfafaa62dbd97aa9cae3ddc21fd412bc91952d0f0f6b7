package com.mmf.zlkypx.factory;

import android.content.Context;
import com.mmf.zlkypx.util.MagiskModuleUtils;

import java.io.*;
import java.util.LinkedHashMap;
import java.util.Map;
import java.util.zip.ZipEntry;
import java.util.zip.ZipInputStream;

/**
 * 功能10：基于 lxgw 模板生成字体替换模块工厂
 * 模板来源：https://github.com/lxgw/simple-cjk-font-magisk-module-template
 * 字重映射: 1=Thin, 2=ExtraLight, 3=Light, 4=Regular, 5=Medium,
 *           6=SemiBold, 7=Bold, 8=ExtraBold, 9=Black
 */
public class FontModuleFactory {

    private static final String ASSETS_TEMPLATE = "template.zip";

    public static final Map<Integer, String> WEIGHT_NAMES = new LinkedHashMap<>();

    static {
        WEIGHT_NAMES.put(1, "Thin");
        WEIGHT_NAMES.put(2, "ExtraLight");
        WEIGHT_NAMES.put(3, "Light");
        WEIGHT_NAMES.put(4, "Regular");
        WEIGHT_NAMES.put(5, "Medium");
        WEIGHT_NAMES.put(6, "SemiBold");
        WEIGHT_NAMES.put(7, "Bold");
        WEIGHT_NAMES.put(8, "ExtraBold");
        WEIGHT_NAMES.put(9, "Black");
    }

    // 字重编号 -> 模板中 EmptyFont 文件名（正体）
    private static final String[] EMPTY_FONT_NAMES = {
            null, // 0 占位
            "EmptyFont-Thin.ttf",       // 1 Thin
            "EmptyFont-Thin.ttf",       // 2 ExtraLight -> 最近似 Thin
            "EmptyFont-Light.ttf",      // 3 Light
            "EmptyFont-Regular.ttf",    // 4 Regular
            "EmptyFont-Medium.ttf",     // 5 Medium
            "EmptyFont-Bold.ttf",       // 6 SemiBold -> Bold
            "EmptyFont-Bold.ttf",       // 7 Bold
            "EmptyFont-Black.ttf",      // 8 ExtraBold -> Black
            "EmptyFont-Black.ttf",      // 9 Black
    };

    /**
     * 创建字体替换模块
     * @param weightFontMap 键=字重编号(1-9)，值=字体文件路径
     */
    public static File createModule(Context context, Map<Integer, File> weightFontMap, File outputDir) throws Exception {
        String timestamp = MagiskModuleUtils.getTimestamp();
        String moduleId = "my_font_" + timestamp;
        String zipName = "MagiskModuleFactory_font_" + timestamp + ".zip";
        File workDir = new File(context.getCacheDir(), "font_builder_" + timestamp);
        workDir.mkdirs();

        // 从 assets 解压完整 lxgw 模板
        extractTemplateZip(context, workDir);

        // 添加用户字体文件（保留模板原有 EmptyFont，以 fontwN.ext 命名）
        File fontsDir = new File(workDir, "system/fonts");
        for (Map.Entry<Integer, File> entry : weightFontMap.entrySet()) {
            int weight = entry.getKey();
            File userFont = entry.getValue();
            if (weight < 1 || weight > 9) continue;
            if (!userFont.exists()) continue;

            String ext = getFileExtension(userFont.getName());
            String targetName = "fontw" + weight + "." + ext;
            copyFile(userFont, new File(fontsDir, targetName));
        }

        // 更新 module.prop 中的 id
        updateModuleProp(workDir, moduleId);

        return createZip(workDir, outputDir, zipName);
    }

    /**
     * 从 assets/template.zip 解压完整 lxgw 模板到 workDir
     */
    private static void extractTemplateZip(Context context, File destDir) throws IOException {
        InputStream is = context.getAssets().open(ASSETS_TEMPLATE);
        ZipInputStream zis = new ZipInputStream(new BufferedInputStream(is));
        byte[] buffer = new byte[8192];

        ZipEntry entry;
        while ((entry = zis.getNextEntry()) != null) {
            String name = entry.getName();
            File outFile = new File(destDir, name);

            if (entry.isDirectory()) {
                outFile.mkdirs();
            } else {
                outFile.getParentFile().mkdirs();
                FileOutputStream fos = new FileOutputStream(outFile);
                int len;
                while ((len = zis.read(buffer)) > 0) {
                    fos.write(buffer, 0, len);
                }
                fos.close();

                // 保持可执行权限（shell 脚本）
                if (name.contains("update-binary") || name.endsWith(".sh")) {
                    outFile.setExecutable(true);
                }
            }
            zis.closeEntry();
        }
        zis.close();
    }

    /**
     * 更新 module.prop 中的 id 字段
     */
    private static void updateModuleProp(File workDir, String moduleId) throws IOException {
        File propFile = new File(workDir, "module.prop");
        if (!propFile.exists()) return;

        StringBuilder sb = new StringBuilder();
        try (BufferedReader br = new BufferedReader(new FileReader(propFile))) {
            String line;
            while ((line = br.readLine()) != null) {
                if (line.startsWith("id=")) {
                    sb.append("id=").append(moduleId).append("\n");
                } else {
                    sb.append(line).append("\n");
                }
            }
        }

        try (FileWriter fw = new FileWriter(propFile)) {
            fw.write(sb.toString());
        }
    }

    private static void copyFile(File source, File dest) throws IOException {
        try (FileInputStream fis = new FileInputStream(source);
             FileOutputStream fos = new FileOutputStream(dest)) {
            byte[] buf = new byte[8192];
            int len;
            while ((len = fis.read(buf)) > 0) {
                fos.write(buf, 0, len);
            }
        }
    }

    private static File createZip(File workDir, File outputDir, String zipName) {
        File zipFile = new File(outputDir, zipName);
        MagiskModuleUtils.zipDirectory(workDir, zipFile);
        deleteRecursive(workDir);
        return zipFile.exists() ? zipFile : null;
    }

    private static void deleteRecursive(File file) {
        if (file.isDirectory()) {
            File[] children = file.listFiles();
            if (children != null) {
                for (File child : children) {
                    deleteRecursive(child);
                }
            }
        }
        file.delete();
    }
}